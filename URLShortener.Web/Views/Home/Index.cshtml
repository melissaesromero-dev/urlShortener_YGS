@model HomeViewModel

@{
    ViewData["Title"] = "URL Shortener";
}

<header class="text-center mb-4">
    <h1>URL Shortener</h1>
    <p class="text-muted">
        Enter a long URL to create a shorter link.
    </p>
</header>

<section class="card shadow-sm mb-4"
         aria-labelledby="shorten-heading">
    <div class="card-body">
        <h2 id="shorten-heading" class="h4">
            Shorten a URL
        </h2>

        <form asp-controller="Home"
              asp-action="Index"
              method="post">
            <fieldset>
                <legend class="visually-hidden">
                    URL details
                </legend>

                <div class="mb-3">
                    <label asp-for="OriginalUrl"
                           class="form-label"></label>

                    <input asp-for="OriginalUrl"
                           class="form-control"
                           placeholder="https://example.com/long-url" />

                    <span asp-validation-for="OriginalUrl"
                          class="text-danger"></span>
                </div>

                <button type="submit"
                        class="btn btn-primary">
                    Shorten URL
                </button>
            </fieldset>
        </form>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.GeneratedShortUrl))
{
    <section class="card shadow-sm mb-4"
             aria-labelledby="result-heading">
        <div class="card-body">
            <h2 id="result-heading" class="h4">
                Your shortened URL
            </h2>

            <output class="d-block">
                <a href="@Model.GeneratedShortUrl"
                   target="_blank"
                   rel="noopener noreferrer">
                    @Model.GeneratedShortUrl
                </a>
            </output>
        </div>
    </section>
       
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}